# Copy this file to .env and fill in your key.
# Never commit .env — it is already in .gitignore.
# AGENTS.md §6.6 requires secrets to be read from environment variables only.

# If using Anthropic Claude API:
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# If using Groq (free tier) — store your Groq key under this same variable:
ANTHROPIC_API_KEY=your_groq_api_key_here
